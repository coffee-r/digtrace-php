{
    "name": "coffee-r/tekagami-data",
    "description": "Language-neutral data processing CLI for tekagami-v1 observation logs",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "doctrine/instantiator": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "TekagamiData\\Report\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TekagamiData\\Tests\\": "tests/"
        }
    }
}
